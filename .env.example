# Environment Variables for Formora

# Stack Auth - Get these from https://app.stack-auth.com
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# Appwrite - Get these from https://cloud.appwrite.io
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=
NEXT_PUBLIC_APPWRITE_DATABASE_ID=
NEXT_PUBLIC_APPWRITE_FORMS_COLLECTION_ID=
NEXT_PUBLIC_APPWRITE_RESPONSES_COLLECTION_ID=
